# Sessao admin (obrigatorio em producao; minimo 32 chars)
SESSION_SECRET=change_this_with_at_least_32_chars

# Prisma
# Ajuste conforme seu banco (PostgreSQL/MySQL/SQL Server/etc)
DATABASE_URL="postgresql://user:password@localhost:5432/site_base"

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_VALIDATE_WEBHOOK_SIGNATURE=false

# Email / notificacoes (SMTP opcional - prioridade para vendas)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SALES_NOTIFICATION_EMAIL=

# Fallback opcional para notificacao
WEB3FORMS_ACCESS_KEY=

# Vercel Blob (upload server-side e token generation)
BLOB_READ_WRITE_TOKEN=vercel_blob_token_here

# Opcional (exemplo de URL publica)
NEXT_PUBLIC_SITE_URL=http://localhost:3003
