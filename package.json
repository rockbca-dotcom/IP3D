{
  "name": "site-rafa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3003",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:api": "vitest run tests/api",
    "test:coverage": "vitest run --coverage",
    "seed": "node scripts/seed-all.js",
    "seed:dev": "node scripts/seed-production.js",
    "seed:prod": "node scripts/seed-production.js",
    "seed:prod:safe": "node scripts/seed-production.js --confirm",
    "create-admin:safe": "node scripts/create-admin.js",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:setup": "prisma migrate deploy && node scripts/seed-production.js",
    "deploy:hostinger": "node scripts/generate-posix-zip.js",
    "analytics:cleanup": "tsx scripts/analytics-cleanup.ts",
    "analytics:cleanup:dry-run": "tsx scripts/analytics-cleanup.ts --dry-run",
    "db:backup": "node scripts/backup-db.js",
    "db:backup:dry-run": "node scripts/backup-db.js --dry-run",
    "db:restore": "node scripts/restore-db.js",
    "db:restore:dry-run": "node scripts/restore-db.js --dry-run"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tiptap/extension-image": "^3.23.4",
    "@tiptap/extension-link": "^3.23.4",
    "@tiptap/extension-placeholder": "^3.23.4",
    "@tiptap/extension-underline": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^3.0.3",
    "beasties": "^0.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "iron-session": "^8.0.4",
    "lucide-react": "^0.560.0",
    "mercadopago": "^2.12.1",
    "next": "16.2.6",
    "nodemailer": "^8.0.7",
    "prisma": "^5.22.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.76.0",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "@supabase/supabase-js": "^2.87.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.41",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.6",
    "archiver": "^7.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "overrides": {
      "undici": ">=6.24.0",
      "markdown-it": ">=14.1.1",
      "postcss": "^8.5.14",
      "next>postcss": "^8.5.14",
      "minimatch": ">=9.0.7",
      "flatted": ">=3.4.2",
      "lodash": ">=4.17.24"
    }
  }
