# ═══════════════════════════════════════════════════════════════════════════════
# IP3D - Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha os valores.
# Em produção, configure estas variáveis diretamente no painel do hosting.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── OBRIGATÓRIOS ─────────────────────────────────────────────────────────────

# Sessão admin (obrigatório; mínimo 32 chars aleatórios)
SESSION_SECRET=change_this_with_at_least_32_chars

# Banco de dados PostgreSQL
# Em produção use a connection string fornecida pelo hosting (Neon, Supabase, Railway, etc)
DATABASE_URL="postgresql://user:password@localhost:5432/ip3d"

# URL pública do site (sem barra no final)
NEXT_PUBLIC_SITE_URL=http://localhost:3003

# ─── UPLOAD DE IMAGENS ────────────────────────────────────────────────────────

# Vercel Blob (para upload de imagens de produtos, banners, etc)
BLOB_READ_WRITE_TOKEN=vercel_blob_token_here

# ─── PAGAMENTOS (opcional) ────────────────────────────────────────────────────

# Gateway ativo (mercadopago | infinitypay)
PAYMENT_PROVIDER=mercadopago

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_VALIDATE_WEBHOOK_SIGNATURE=false

# InfinityPay
INFINITYPAY_HANDLE=
INFINITYPAY_API_KEY=
INFINITYPAY_WEBHOOK_URL=
INFINITYPAY_REDIRECT_URL=
INFINITYPAY_WEBHOOK_SECRET=

# ─── EMAIL / NOTIFICAÇÕES (opcional) ─────────────────────────────────────────

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SALES_NOTIFICATION_EMAIL=

# Fallback para notificações (se SMTP não configurado)
WEB3FORMS_ACCESS_KEY=
