# .env.example - IP3D
# Copie este arquivo para .env e preencha com suas credenciais.
# NUNCA coloque secrets reais no repositório.

# -----------------------------------------------------------------------------
# CORE (Obrigatórios)
# -----------------------------------------------------------------------------

# URL de conexão com o banco PostgreSQL.
# Exemplo local (Docker): postgresql://postgres:password@localhost:5432/ip3d?schema=public
DATABASE_URL="postgresql://user:password@host:port/dbname?schema=public"

# Segredo para criptografia da sessão (iron-session).
# Obrigatório ter no mínimo 32 caracteres. Use um gerador de senhas.
SESSION_SECRET="CHANGE_ME_IN_PRODUCTION_MUST_BE_32_CHARS"

# URL pública do site. Usada para sitemaps, redirecionamentos e webhooks.
# No desenvolvimento, use http://localhost:3000
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Supabase HTTP bridge para auth/health em ambientes serverless.
# Necessário quando o painel admin valida usuário via PostgREST.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""

# Segredo para proteger o setup inicial do administrador (/api/auth/setup).
# Opcional, mas recomendado em produção para evitar que o setup fique aberto antes do primeiro admin.
# Deve ser enviado no header 'X-Setup-Secret'.
# ADMIN_SETUP_SECRET="change-me-to-a-secure-secret"

# -----------------------------------------------------------------------------
# PAGAMENTOS (Selecione um provedor)
# -----------------------------------------------------------------------------

# Provedor ativo: 'mercadopago' ou 'infinitypay'
PAYMENT_PROVIDER="mercadopago"

# --- MERCADO PAGO ---
# Obrigatório se PAYMENT_PROVIDER="mercadopago"
MERCADO_PAGO_ACCESS_TOKEN=""
# Secret para validar a assinatura dos webhooks (opcional no dev, recomendado em prod)
MERCADO_PAGO_WEBHOOK_SECRET=""
# Ative como "true" somente depois que MERCADO_PAGO_WEBHOOK_SECRET estiver configurado.
MERCADO_PAGO_VALIDATE_WEBHOOK_SIGNATURE="false"
# Opcional: sobrescreve a URL automatica baseada em NEXT_PUBLIC_SITE_URL.
# MERCADO_PAGO_WEBHOOK_URL=""

# --- INFINITYPAY ---
# Obrigatórios se PAYMENT_PROVIDER="infinitypay"
INFINITYPAY_HANDLE=""
INFINITYPAY_API_KEY=""
INFINITYPAY_WEBHOOK_SECRET=""
# URLs Opcionais (possuem fallbacks automáticos baseados no NEXT_PUBLIC_SITE_URL)
# INFINITYPAY_REDIRECT_URL=""
# INFINITYPAY_WEBHOOK_URL=""

# -----------------------------------------------------------------------------
# NOTIFICAÇÕES & EMAILS (Opcionais)
# -----------------------------------------------------------------------------

# --- SMTP (Envio direto) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="contato@seudominio.com"

# --- Web3Forms (Fallback/Alternativa ao SMTP) ---
WEB3FORMS_ACCESS_KEY=""

# --- Configurações de Recebimento ---
# Email que receberá as notificações de novas vendas.
SALES_NOTIFICATION_EMAIL="admin@seudominio.com"

# -----------------------------------------------------------------------------
# ASSETS & STORAGE (Opcionais)
# -----------------------------------------------------------------------------

# Vercel Blob (para upload de imagens no painel admin)
BLOB_READ_WRITE_TOKEN=""
NEXT_PUBLIC_BLOB_URL=""

# -----------------------------------------------------------------------------
# AMBIENTE (Automático no Vercel/Next)
# -----------------------------------------------------------------------------
NODE_ENV="development"
